# Eye Test Engine – copy to .env and fill in your values
# Session CSVs are saved locally; set REMOTE_STORAGE=supabase to also save to Supabase Storage.

# ----- Supabase (optional) -----
# Set to "supabase" to upload session CSV + metadata to your Supabase bucket when a session is stored.
REMOTE_STORAGE=supabase

# From Supabase dashboard: Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Use the service_role key (secret), NOT the anon/publishable key, or uploads will fail.
SUPABASE_SERVICE_KEY=your-service-role-key
# Or use SUPABASE_KEY instead of SUPABASE_SERVICE_KEY.

# Bucket name in Storage (create in Supabase dashboard → Storage). Default: eye-test-sessions
# SUPABASE_BUCKET=eye-test-sessions

# ----- Server (optional) -----
# HOST=0.0.0.0
# PORT=5050
# BACKEND_URL=
# PHOROPTER_BASE_URL=https://rajasthan-royals.preprod.lenskart.com
